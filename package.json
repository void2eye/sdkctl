{
  "name": "@void2eye/sdkctl",
  "version": "0.1.3",
  "description": "A small, cross-platform SDK version manager",
  "type": "module",
  "bin": {
    "sdkctl": "bin/sdkctl.js",
    "sdk": "bin/sdkctl.js"
  },
  "scripts": {
    "test": "node --test",
    "start": "node bin/sdkctl.js",
    "build:exe": "node scripts/build-standalone.mjs",
    "build:installer": "npm run build:exe && node scripts/build-installer.mjs",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6"
  }
}
